{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "disabled_agents": [],
  "autoUpdate": false,
  "preset": "default",
  "presets": {
    "default": {
      "orchestrator": {
        "model": "volcengine-plan/glm-5.2",
        "skills": ["*"],
        "mcps": ["*", "!context7"]
      },
      "oracle": {
        "model": "volcengine-plan/kimi-k2.6",
        "variant": "high",
        "skills": ["simplify", "code-review-and-quality", "api-and-interface-design"],
        "mcps": []
      },
      "librarian": {
        "model": "volcengine-plan/deepseek-v4-pro",
        "variant": "medium",
        "skills": [],
        "mcps": ["websearch", "context7", "grep_app"]
      },
      "explorer": {
        "model": "volcengine-plan/deepseek-v4-flash",
        "variant": "medium",
        "skills": ["codemap", "clonedeps", "source-driven-development"],
        "mcps": []
      },
      "designer": {
        "model": "volcengine-plan/kimi-k2.6",
        "variant": "medium",
        "skills": ["browser-testing-with-devtools", "frontend-ui-engineering"],
        "mcps": []
      },
      "fixer": {
        "model": "volcengine-plan/glm-5.2",
        "variant": "high",
        "skills": ["clean-code", "incremental-implementation", "debugging-and-error-recovery", "test-driven-development"],
        "mcps": []
      },
      "observer": {
        "model": "volcengine-plan/kimi-k2.6"
      }
    }
  },
  "council": {
    "default_preset": "default",
    "master": { "model": "volcengine-plan/glm-5.2" },
    "presets": {
      "default": {
        "beta": { "model": "volcengine-plan/kimi-k2.6" },
        "gamma": { "model": "volcengine-plan/deepseek-v4-pro", "variant": "max" }
      }
    }
  },
  "todoContinuation": {
    "autoEnable": true,
    "autoEnableThreshold": 4,
    "maxContinuations": 50,
    "cooldownMs": 3000
  }
}
