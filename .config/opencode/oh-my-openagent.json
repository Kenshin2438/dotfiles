{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "model_fallback": true,
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "agents": {
    "sisyphus": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        "deepseek/deepseek-v4-pro",
        "opencode-go/qwen3.6-plus"
      ],
      "ultrawork": {
        "model": "opencode-go/kimi-k2.6",
        "variant": "max"
      }
    },
    "hephaestus": {
      "model": "deepseek/deepseek-v4-pro",
      "fallback_models": [
        "deepseek/deepseek-v4-flash",
        "opencode-go/kimi-k2.6"
      ],
      "prompt_append": "Explore thoroughly, then implement. Prefer small, testable changes."
    },
    "oracle": {
      "model": "opencode-go/glm-5.1",
      "fallback_models": ["opencode-go/kimi-k2.6", "deepseek/deepseek-v4-pro"]
    },
    "librarian": {
      "model": "deepseek/deepseek-v4-flash",
      "fallback_models": ["opencode-go/qwen3.5-plus"]
    },
    "explore": {
      "model": "deepseek/deepseek-v4-flash"
    },
    "multimodal-looker": {
      "model": "opencode-go/mimo-v2-omni",
      "fallback_models": ["opencode-go/qwen3.6-plus"]
    },
    "prometheus": {
      "model": "opencode-go/glm-5.1",
      "fallback_models": [
        "opencode-go/qwen3.6-plus",
        "deepseek/deepseek-v4-pro"
      ],
      "prompt_append": "Always interview first. Validate scope before planning."
    },
    "metis": {
      "model": "opencode-go/qwen3.6-plus",
      "fallback_models": ["deepseek/deepseek-v4-pro"]
    },
    "momus": {
      "model": "opencode-go/qwen3.6-plus",
      "fallback_models": ["opencode-go/kimi-k2.6"]
    },
    "atlas": {
      "model": "deepseek/deepseek-v4-pro",
      "fallback_models": ["deepseek/deepseek-v4-flash"]
    },
    "code-reviewer": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": ["deepseek/deepseek-v4-pro"]
    },
    "sisyphus-junior": {
      "model": "deepseek/deepseek-v4-flash"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "opencode-go/mimo-v2-omni",
      "fallback_models": ["opencode-go/qwen3.6-plus"]
    },
    "ultrabrain": {
      "model": "opencode-go/glm-5.1",
      "fallback_models": ["opencode-go/kimi-k2.6"]
    },
    "deep": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": ["deepseek/deepseek-v4-pro"]
    },
    "artistry": {
      "model": "opencode-go/glm-5.1",
      "fallback_models": ["opencode-go/qwen3.6-plus"]
    },
    "quick": {
      "model": "deepseek/deepseek-v4-flash"
    },
    "unspecified-low": {
      "model": "deepseek/deepseek-v4-flash"
    },
    "unspecified-high": {
      "model": "deepseek/deepseek-v4-pro",
      "fallback_models": ["opencode-go/kimi-k2.6"]
    },
    "writing": {
      "model": "opencode-go/qwen3.6-plus"
    }
  },
  "background_task": {
    "defaultConcurrency": 5,
    "staleTimeoutMs": 180000,
    "providerConcurrency": {
      "opencode-go": 10,
      "deepseek": 50
    },
    "modelConcurrency": {
      "opencode-go/kimi-k2.6": 2,
      "deepseek/deepseek-v4-pro": 3,
      "deepseek/deepseek-v4-flash": 20,
      "opencode-go/glm-5.1": 1,
      "opencode-go/qwen3.6-plus": 5
    }
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  }
}
